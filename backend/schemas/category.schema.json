{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.babylove.local/schemas/category.schema.json",
  "title": "Category",
  "type": "object",
  "required": [
    "id",
    "slug",
    "icon",
    "parentId",
    "en",
    "ar",
    "displayOrder",
    "isActive",
    "typeKeys",
    "seo",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "description": "Unique category identifier.",
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "string", "minLength": 1 }
      ]
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "icon": {
      "type": "string",
      "minLength": 1
    },
    "parentId": {
      "oneOf": [
        { "type": "null" },
        { "type": "integer", "minimum": 1 },
        { "type": "string", "minLength": 1 }
      ]
    },
    "displayOrder": {
      "type": "integer",
      "minimum": 1
    },
    "isActive": {
      "type": "boolean"
    },
    "typeKeys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "en": {
      "$ref": "#/$defs/categoryContent"
    },
    "ar": {
      "$ref": "#/$defs/categoryContent"
    },
    "seo": {
      "type": "object",
      "required": ["title", "description", "keywords"],
      "properties": {
        "title": { "type": "string", "minLength": 2, "maxLength": 160 },
        "description": { "type": "string", "minLength": 2, "maxLength": 500 },
        "keywords": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 80 }
        }
      },
      "additionalProperties": false
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "categoryContent": {
      "type": "object",
      "required": ["title", "description", "types"],
      "properties": {
        "title": { "type": "string", "minLength": 2, "maxLength": 120 },
        "description": { "type": "string", "minLength": 2, "maxLength": 500 },
        "types": {
          "description": "Localized labels in the same order as typeKeys.",
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  }
}
