{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.babylove.local/schemas/testimonial.schema.json",
  "title": "Testimonial",
  "type": "object",
  "required": ["id", "en", "ar", "rating", "isActive", "createdAt", "updatedAt"],
  "properties": {
    "id": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "string", "minLength": 1 }
      ]
    },
    "en": {
      "$ref": "#/$defs/content"
    },
    "ar": {
      "$ref": "#/$defs/content"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    },
    "isActive": {
      "type": "boolean"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "content": {
      "type": "object",
      "required": ["quote", "author", "role"],
      "properties": {
        "quote": {
          "type": "string",
          "minLength": 2,
          "maxLength": 600
        },
        "author": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "role": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        }
      },
      "additionalProperties": false
    }
  }
}
