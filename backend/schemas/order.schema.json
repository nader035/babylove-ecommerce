{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.babylove.local/schemas/order.schema.json",
  "title": "Order",
  "type": "object",
  "required": [
    "id",
    "userId",
    "date",
    "status",
    "total",
    "items",
    "shippingAddress",
    "currency",
    "paymentMethod",
    "paymentStatus",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "string", "minLength": 1 }
      ]
    },
    "userId": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "string", "minLength": 1 }
      ]
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "processing", "shipped", "delivered", "cancelled"]
    },
    "total": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "enum": ["USD", "EGP", "EUR", "SAR", "AED"]
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/orderItem"
      }
    },
    "shippingAddress": {
      "$ref": "#/$defs/shippingAddress"
    },
    "paymentMethod": {
      "type": "string",
      "enum": ["credit_card", "cash_on_delivery", "wallet", "bank_transfer"]
    },
    "paymentStatus": {
      "type": "string",
      "enum": ["pending", "completed", "refunded", "failed"]
    },
    "trackingCode": {
      "oneOf": [{ "type": "string", "minLength": 1, "maxLength": 100 }, { "type": "null" }]
    },
    "itemCount": {
      "type": "integer",
      "minimum": 0
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "orderItem": {
      "type": "object",
      "required": ["id", "productId", "skuId", "quantity", "price", "lineTotal", "title", "image"],
      "properties": {
        "id": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "productId": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "skuId": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "quantity": {
          "type": "integer",
          "minimum": 1
        },
        "price": {
          "type": "number",
          "minimum": 0
        },
        "lineTotal": {
          "type": "number",
          "minimum": 0
        },
        "title": {
          "$ref": "#/$defs/localizedString"
        },
        "image": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "localizedString": {
      "type": "object",
      "required": ["en", "ar"],
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "ar": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "shippingAddress": {
      "type": "object",
      "required": ["fullName", "street", "city", "country"],
      "properties": {
        "fullName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "street": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        }
      },
      "additionalProperties": false
    }
  }
}
